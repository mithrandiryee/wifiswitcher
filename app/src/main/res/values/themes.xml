<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="Theme.WiFiSwitcher" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
    </style>
    
    <!-- NoActionBar theme for activities with Toolbar -->
    <style name="Theme.WiFiSwitcher.NoActionBar" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
    </style>
    
    <!-- TV theme -->
    <style name="Theme.WiFiSwitcher.TV" parent="Theme.WiFiSwitcher.NoActionBar">
        <item name="android:windowBackground">@color/background_dark</item>
    </style>
</resources>
